---
// Hero con video de fondo real (procesos reales del cliente) + marca de agua.
// El video (11 MB) se carga por JS solo en desktop y sin prefers-reduced-motion;
// en movil / reduced-motion se muestra solo el poster (frame fijo).
const metricas = [
  // MÉTRICAS placeholder — confirmar cifras reales con Ariel.
  { valor: "+30", label: "Años de experiencia internacional" },
  { valor: "+24", label: "Marcas líderes confían en SDI" },
  { valor: "100%", label: "Proyectos llave en mano" },
];
---

<section class="hero" id="top">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    poster="/assets/video/hero-sorter-poster.jpg"
    aria-hidden="true"
    data-hero-video
    data-src="/assets/video/hero-sorter.mp4"
  >
  </video>

  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__watermark" aria-hidden="true">
    <img src="/assets/logos/sdi-icon.png" alt="" width="458" height="468" loading="lazy" />
  </div>

  <div class="container hero__content">
    <span class="hero__eyebrow" data-reveal>Automatización · Intralogística · LATAM</span>
    <h1 class="hero__title" data-reveal style="--reveal-delay:.06s">
      Automatización e <span class="hero__hl">Inteligencia Logística</span> para
      LATAM
    </h1>
    <p class="hero__subtitle" data-reveal style="--reveal-delay:.14s">
      Diseñamos, integramos e implementamos centros de distribución llave en
      mano. Transformamos operaciones logísticas en ventajas competitivas.
    </p>
    <div class="hero__cta" data-reveal style="--reveal-delay:.22s">
      <a href="#contacto" class="btn btn-gold">Contáctanos</a>
      <a href="#soluciones" class="btn btn-outline">Ver soluciones</a>
    </div>

    <dl class="hero__metrics" data-reveal style="--reveal-delay:.3s">
      {
        metricas.map((m) => (
          <div class="hero__metric">
            <dt class="hero__metric-num">{m.valor}</dt>
            <dd class="hero__metric-label">{m.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-h);
    overflow: hidden;
    color: var(--white);
    background: var(--brand-navy-deep);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  /* Scrim oscuro (navy de marca) para legibilidad del texto */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      105deg,
      rgba(42, 45, 54, 0.92) 0%,
      rgba(42, 45, 54, 0.6) 45%,
      rgba(42, 45, 54, 0.25) 100%
    );
  }

  /* Marca de agua: logo gris, centrado, detras del texto y sobre el scrim */
  .hero__watermark {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.15;
    animation: hero-wm-fade 1.5s ease both;
  }

  .hero__watermark img {
    /* Icono circular (~1:1): mas compacto que el logo horizontal anterior */
    width: clamp(360px, 46vw, 640px);
    height: auto;
    filter: grayscale(1);
  }

  @keyframes hero-wm-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 0.15;
    }
  }

  .hero__content {
    position: relative;
    z-index: 3;
    max-width: 880px;
    padding-block: clamp(3rem, 8vw, 5.5rem);
  }

  .hero__eyebrow {
    display: inline-block;
    font-family: var(--font-head);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-gold);
    margin-bottom: 1.1rem;
  }

  .hero__title {
    color: var(--white);
    font-size: clamp(2.3rem, 6.2vw, 4.4rem);
    font-weight: 700;
    line-height: 1.04;
    max-width: 17ch;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.32);
  }

  .hero__hl {
    color: var(--brand-gold);
  }

  .hero__subtitle {
    margin-top: 1.4rem;
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    color: #e9ebf1;
    max-width: 52ch;
    line-height: 1.55;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }

  .hero__cta {
    margin-top: 2.2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Métricas sobre el scrim */
  .hero__metrics {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: clamp(1.5rem, 5vw, 3.5rem);
    justify-content: start;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 1.75rem;
  }

  .hero__metric-num {
    font-family: var(--font-head);
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1;
    color: var(--white);
  }

  .hero__metric-label {
    margin-top: 0.45rem;
    font-size: 0.86rem;
    color: #c8cbd4;
    max-width: 18ch;
    line-height: 1.35;
  }

  /* En movil: scrim mas opaco para asegurar legibilidad */
  @media (max-width: 720px) {
    .hero__scrim {
      background: linear-gradient(
        160deg,
        rgba(42, 45, 54, 0.94) 0%,
        rgba(42, 45, 54, 0.82) 50%,
        rgba(42, 45, 54, 0.66) 100%
      );
    }

    .hero__watermark img {
      width: clamp(240px, 70vw, 420px);
    }

    .hero__metrics {
      gap: 1.25rem 1.5rem;
    }

    .hero__metric-label {
      font-size: 0.78rem;
    }
  }

  /* Sin animacion si el usuario lo pide */
  @media (prefers-reduced-motion: reduce) {
    .hero__watermark {
      animation: none;
      opacity: 0.15;
    }
  }
</style>

<script>
  // Carga el video solo en desktop y sin prefers-reduced-motion.
  // En movil / reduced-motion queda el poster (evita bajar ~11 MB).
  const video = document.querySelector<HTMLVideoElement>("[data-hero-video]");
  if (video) {
    const wantsVideo =
      window.matchMedia("(min-width: 768px)").matches &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (wantsVideo) {
      const src = video.dataset.src;
      if (src) {
        const source = document.createElement("source");
        source.src = src;
        source.type = "video/mp4";
        video.appendChild(source);
        video.load();
        // Algunos navegadores requieren play() explicito tras inyectar source
        video.play?.().catch(() => {});
      }
    }
  }
</script>
