---
// Hero con video de fondo. Archivos en public/assets/video/.
// El logo SDI NO va aqui (queda en el navbar).
---

<section class="hero" id="top">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    poster="/assets/video/hero-poster.jpg"
  >
    <source src="/assets/video/hero-loop.mp4" type="video/mp4" />
  </video>

  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="container hero__content">
    <h1 class="hero__title" data-reveal>
      Automatización e <span class="hero__hl">Inteligencia Logística</span> para
      LATAM
    </h1>
    <p class="hero__subtitle" data-reveal style="--reveal-delay:.1s">
      Transformamos operaciones logísticas en ventajas competitivas.
    </p>
    <div class="hero__cta" data-reveal style="--reveal-delay:.2s">
      <a href="#contacto" class="btn btn-gold">Contáctanos</a>
      <a href="#soluciones" class="btn btn-outline">Ver soluciones</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-h);
    overflow: hidden;
    color: var(--white);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* Scrim oscuro para legibilidad del texto */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      105deg,
      rgba(20, 25, 35, 0.85) 0%,
      rgba(20, 25, 35, 0.55) 45%,
      rgba(20, 25, 35, 0.15) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 820px;
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .hero__title {
    color: var(--white);
    font-size: clamp(2.1rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.06;
    max-width: 16ch;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
  }

  .hero__hl {
    color: var(--brand-gold);
  }

  .hero__subtitle {
    margin-top: 1.25rem;
    font-size: clamp(1.05rem, 2.4vw, 1.4rem);
    color: #eef0f6;
    max-width: 46ch;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }

  .hero__cta {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* En movil: scrim mas opaco para asegurar legibilidad */
  @media (max-width: 720px) {
    .hero__scrim {
      background: linear-gradient(
        160deg,
        rgba(20, 25, 35, 0.92) 0%,
        rgba(20, 25, 35, 0.78) 50%,
        rgba(20, 25, 35, 0.6) 100%
      );
    }
  }
</style>
