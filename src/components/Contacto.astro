---
// Datos de contacto: PLACEHOLDERS pendientes de Ariel.
// Form: reemplazar TU_FORM_ID por el endpoint real de Formspree (formspree.io).
const WHATSAPP = "56900000000"; // <- numero real pendiente
const EMAIL = "contacto@sdisystems.cl"; // <- correo real pendiente
const FORMSPREE = "https://formspree.io/f/TU_FORM_ID"; // <- endpoint real pendiente
---

<section class="section section--navy" id="contacto">
  <div class="container contacto">
    <div class="contacto__intro">
      <span class="eyebrow">Contacto</span>
      <h2 class="section-title">Hablemos de tu centro de distribución</h2>
      <p class="section-intro">
        Cuéntanos tu desafío logístico y te proponemos una solución a medida.
        Respondemos desde LATAM, en tu mismo idioma y zona horaria.
      </p>

      <div class="contacto__direct">
        <a class="contacto__chip" href={`https://wa.me/${WHATSAPP}`} rel="noopener" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2a9.9 9.9 0 00-8.43 15.16L2 22l4.95-1.3A9.9 9.9 0 1012.04 2zm0 1.8a8.1 8.1 0 11-4.13 15.06l-.3-.18-2.94.77.78-2.86-.2-.31A8.1 8.1 0 0112.04 3.8zm4.64 9.9c-.25-.13-1.47-.72-1.7-.8-.23-.09-.4-.13-.56.13-.17.25-.64.8-.79.96-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.47-1.38-1.72-.15-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.13-.15.17-.25.25-.42.08-.17.04-.31-.02-.43-.06-.13-.56-1.35-.77-1.85-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.74 2.66 4.22 3.73.59.26 1.05.41 1.41.52.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.23-.17-.48-.3z"/>
          </svg>
          WhatsApp
        </a>
        <a class="contacto__chip" href={`mailto:${EMAIL}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7l9 6 9-6" />
          </svg>
          {EMAIL}
        </a>
      </div>
    </div>

    <form class="contacto__form" action={FORMSPREE} method="POST">
      <div class="field">
        <label for="nombre">Nombre</label>
        <input id="nombre" name="nombre" type="text" required autocomplete="name" />
      </div>
      <div class="field">
        <label for="empresa">Empresa</label>
        <input id="empresa" name="empresa" type="text" autocomplete="organization" />
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="field">
        <label for="mensaje">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="4" required></textarea>
      </div>
      <button type="submit" class="btn btn-gold contacto__submit">Enviar mensaje</button>
      <p class="contacto__note">
        Al enviar aceptas que te contactemos respecto a tu consulta.
      </p>
    </form>
  </div>
</section>

<style>
  .contacto {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .contacto__direct {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .contacto__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--white);
    padding: 0.65rem 1.1rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.92rem;
    transition: background var(--t), border-color var(--t);
  }

  .contacto__chip:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: var(--brand-gold);
    color: var(--white);
  }

  .contacto__chip svg {
    width: 20px;
    height: 20px;
  }

  .contacto__form {
    background: var(--white);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    box-shadow: var(--shadow-lg);
    display: grid;
    gap: 1rem;
  }

  .field {
    display: grid;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--brand-navy);
  }

  .field input,
  .field textarea {
    font: inherit;
    color: var(--brand-navy);
    background: var(--bg-light);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.85rem;
    width: 100%;
    transition: border-color var(--t), box-shadow var(--t), background var(--t);
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    background: var(--white);
    border-color: var(--brand-blue);
    box-shadow: 0 0 0 3px rgba(67, 127, 172, 0.18);
  }

  .field textarea {
    resize: vertical;
    min-height: 110px;
  }

  .contacto__submit {
    margin-top: 0.25rem;
    justify-content: center;
  }

  .contacto__note {
    font-size: 0.8rem;
    color: var(--muted);
    text-align: center;
  }

  @media (max-width: 860px) {
    .contacto {
      grid-template-columns: 1fr;
    }
  }
</style>
