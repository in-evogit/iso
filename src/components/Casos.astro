---
// Casos de exito — formato problema -> solucion -> resultado, con metricas.
// El muro de clientes se movio al carrusel (Clientes.astro), aqui van solo casos.
// Atribucion fresco/congelado + transelevador 740 = PF Alimentos (segun fuente).
// NOTA: las metricas marcadas "(placeholder)" deben confirmarse con Ariel.
const casos = [
  {
    cliente: "Dimerc",
    logo: "/assets/clientes/dimerc.png",
    foto: "/assets/img/casos/dimerc-picking-unidades.png",
    problema:
      "Surtido mixto de cajas y unidades hacia tiendas, con alta exigencia de precisión y volumen.",
    solucion:
      "Picking de cajas (torres de picking, pick-to-pallet, sorter a tiendas) y picking de unidades (pick-to-light, RF, balanza de validación).",
    resultado: "Operación de picking mixta, más rápida y con menos errores.",
    metricas: [
      { valor: "+25%", label: "líneas por hora", ph: true },
      { valor: "−30%", label: "errores de picking", ph: true },
    ],
  },
  {
    cliente: "Soprole",
    logo: "/assets/clientes/soprole.png",
    foto: "/assets/img/casos/soprole-picking.jpg",
    problema:
      "Reposición a tiendas con alto volumen y necesidad de estandarizar el picking.",
    solucion:
      "Picking de cajas (pick-to-belt, sorter a tiendas) y picking de unidades (pick-to-light).",
    resultado: "Despacho a tiendas más ágil y estandarizado.",
    metricas: [
      { valor: "+30%", label: "productividad", ph: true },
      { valor: "2x", label: "velocidad de despacho", ph: true },
    ],
  },
  {
    cliente: "PF Alimentos",
    logo: "/assets/clientes/pf-alimentos.png",
    foto: "/assets/img/casos/pf-alimentos-layout.png",
    problema:
      "Operación con cadena de frío (0–4°), congelado (−28°) y manejo de pallets.",
    solucion:
      "5 torres de picking, sorter a rutas, sistemas para fresco (0–4°) y congelado (−28°), y transelevador de 740 posiciones (pallets).",
    resultado: "Centro de distribución con fresco, congelado y pallets integrados.",
    metricas: [
      { valor: "740", label: "posiciones de transelevador", ph: false },
      { valor: "−28°C", label: "operación en congelado", ph: false },
    ],
  },
];
---

<section class="section blueprint" id="casos">
  <div class="container">
    <div class="section-head section-head--center">
      <span class="eyebrow">Casos de Éxito</span>
      <h2 class="section-title">Proyectos reales, resultados en operación</h2>
      <p class="section-intro">
        Proyectos implementados en centros de distribución de Chile y LATAM, del
        problema operativo al resultado en planta.
      </p>
    </div>

    <div class="casos">
      {
        casos.map((caso, i) => (
          <article class="caso" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <div class="caso__media">
              <img
                src={caso.foto}
                alt={`Proyecto SDI Systems en ${caso.cliente}`}
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="caso__body">
              <div class="caso__head">
                <img class="caso__logo" src={caso.logo} alt={caso.cliente} loading="lazy" />
                <h3 class="caso__name">{caso.cliente}</h3>
              </div>

              <dl class="caso__flow">
                <div class="caso__step">
                  <dt class="caso__label">Problema</dt>
                  <dd>{caso.problema}</dd>
                </div>
                <div class="caso__step">
                  <dt class="caso__label caso__label--sol">Solución SDI</dt>
                  <dd>{caso.solucion}</dd>
                </div>
                <div class="caso__step">
                  <dt class="caso__label caso__label--res">Resultado</dt>
                  <dd>{caso.resultado}</dd>
                </div>
              </dl>

              <ul class="caso__metrics">
                {caso.metricas.map((m) => (
                  <li class="caso__metric">
                    <span class="caso__metric-num">{m.valor}</span>
                    <span class="caso__metric-label">{m.label}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .casos {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }

  .caso {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  /* Alterna el lado de la imagen para dar ritmo */
  .caso:nth-child(even) .caso__media {
    order: 2;
  }

  .caso__media {
    align-self: stretch;
    min-height: 280px;
    background: var(--brand-navy);
    overflow: hidden;
  }

  .caso__media img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
  }

  .caso__body {
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .caso__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .caso__logo {
    height: 30px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    object-position: left;
  }

  .caso__name {
    font-size: 1.3rem;
  }

  .caso__flow {
    display: grid;
    gap: 1.1rem;
  }

  .caso__step {
    padding-left: 1rem;
    border-left: 2px solid var(--line);
  }

  .caso__step dd {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .caso__label {
    display: block;
    font-family: var(--font-head);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted); /* AA sobre blanco */
    margin-bottom: 0.3rem;
  }

  .caso__label--sol {
    color: var(--brand-blue);
  }

  .caso__label--res {
    color: var(--brand-navy); /* AA sobre blanco (el dorado falla en texto pequeño) */
  }

  .caso__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .caso__metric-num {
    display: block;
    font-family: var(--font-head);
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1;
    color: var(--brand-navy);
  }

  .caso__metric-label {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.82rem;
    color: var(--muted); /* AA sobre blanco */
    max-width: 16ch;
  }

  @media (max-width: 820px) {
    .caso {
      grid-template-columns: 1fr;
    }
    .caso:nth-child(even) .caso__media {
      order: 0;
    }
    .caso__media,
    .caso__media img {
      min-height: 220px;
      max-height: 300px;
    }
  }
</style>
